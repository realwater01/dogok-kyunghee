# Supabase — Project Settings > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Solapi 알림톡 — 상담 신청 시 한의원 카카오톡으로 알림 발송
# https://solapi.com 가입 후 발급
SOLAPI_API_KEY=your-api-key
SOLAPI_API_SECRET=your-api-secret
SOLAPI_PF_ID=your-kakao-pf-id          # 카카오 발신프로필 키
SOLAPI_TEMPLATE_ID=your-template-id    # 승인된 알림톡 템플릿 ID
SOLAPI_FROM=0212345678                 # 솔라피에 사전 등록한 발신번호
CLINIC_NOTIFY_TO=01012345678           # 알림을 받을 한의원 휴대폰 번호
